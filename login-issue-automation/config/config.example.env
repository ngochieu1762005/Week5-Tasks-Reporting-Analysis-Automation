# Odoo configuration
ODOO_URL=https://your-odoo-domain.com
ODOO_DB=your_database
ODOO_USERNAME=your_email@example.com
ODOO_API_KEY=your_api_key

# Odoo model/stage/tag configuration
ODOO_HELPDESK_MODEL=helpdesk.ticket
ODOO_SOLVED_STAGE_ID=4
ODOO_MANUAL_REVIEW_STAGE_ID=3

# Runtime mode
DRY_RUN=true
LOG_LEVEL=INFO

# Webhook server
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_SECRET=change-this-secret
